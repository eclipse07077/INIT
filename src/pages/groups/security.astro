---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Steps from '~/components/widgets/Steps.astro';

const metadata = {
  title: '정보보안 연구 그룹',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="정보보안 연구 그룹" title="정보보안 연구 그룹" subtitle="티어별 활동 및 승급 조건 안내입니다." />

  <Steps
    title="티어 시스템"
    items={[
      {
        title: '4티어: <span class="font-medium">분야 결정 기간</span>',
        description: `분야 선택: 웹해킹, 리버싱, 포너블, 암호학, 포렌식, 블록체인, OSINT<br/><br/>
          <strong>학습:</strong> 분야별 기초적인 워게임 풀이 및 분석<br/><br/>
          <strong>3티어 승급 조건:</strong> 본인 분야 워게임 5문제 이상 풀이`,
        icon: 'tabler:number-4',
      },
      {
        title: '3티어',
        description: `<strong>학습:</strong> 오픈소스 분석 또는 더 어려운 워게임 풀이<br/><br/>
          <strong>2티어 승급 조건:</strong> 논문 한 편 게재, CVE 또는 KVE 발급, 관련 대회 참여 (본선 진출 또는 수상)`,
        icon: 'tabler:number-3',
      },
      {
        title: '2티어',
        description: `자율적 대외활동<br/><br/>
          <strong>1티어 승급 조건:</strong> 관련 국가기관 연구소 교육생 또는 인턴 합격, 대기업 연계 부트캠프 합격`,
        icon: 'tabler:number-2',
      },
      {
        title: '1티어',
        description: '자율적 대외활동',
        icon: 'tabler:number-1',
      },
    ]}
  />
</Layout>
